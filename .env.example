# Copy this file to .env and fill in your key.
# .env is gitignored — your real key never gets committed.
#
# Get a key at https://openrouter.ai/ — every model (Claude, GPT, etc.)
# runs through this one key, since all model calls go through OpenRouter.
# This is only used by the local demo script (scripts/run_example.py) —
# a real website backend would receive each visitor's own key per
# request instead of reading one from a file.

OPENROUTER_API_KEY=
