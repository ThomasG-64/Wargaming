# Copy this file to .env and fill in what you use.
# .env is gitignored — your real secrets never get committed.

# OpenRouter key: used by the local demo script (scripts/run_example.py).
# The website instead has each visitor paste their own key per run.
# Get one at https://openrouter.ai/
OPENROUTER_API_KEY=

# Claude Code CLI billing pin (optional, for the website's claude_code
# backend): without this, CLI runs bill whatever Claude account the
# `claude` CLI on this machine is logged into — easy to get wrong if the
# machine has both a personal and a work login. To pin billing to a
# specific account, run `claude setup-token` while signed into that
# account and paste the resulting sk-ant-oat... token here, then restart
# the web server.
CLAUDE_CODE_OAUTH_TOKEN=
